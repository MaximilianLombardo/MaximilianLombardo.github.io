---
// Nav.astro: sticky translucent top bar
---

<nav>
  <div class="wrap">
    <a href="/" class="brand" aria-label="Maximilian Lombardo, home">
      <svg class="logo" viewBox="0 0 32 32" aria-hidden="true">
        <!-- red isometric extrusion (behind) -->
        <polyline class="ext" points="8,22.5 8,9.5 15,16.5 22,9.5 22,22.5" />
        <line class="ext" x1="7" y1="23" x2="8" y2="22.5" />
        <line class="ext" x1="7" y1="10" x2="8" y2="9.5" />
        <line class="ext" x1="14" y1="17" x2="15" y2="16.5" />
        <line class="ext" x1="21" y1="10" x2="22" y2="9.5" />
        <line class="ext" x1="21" y1="23" x2="22" y2="22.5" />
        <!-- white front M -->
        <polyline class="front" points="7,23 7,10 14,17 21,10 21,23" />
      </svg>
    </a>
    <span class="nlinks">
      <span class="dropdown">
        <button type="button" class="trigger" aria-haspopup="true" aria-expanded="false">
          WORK <span class="caret" aria-hidden="true">▾</span>
        </button>
        <div class="menu">
          <a href="/work/biohub">Biohub</a>
          <a href="/work/kallyope">Kallyope</a>
          <a href="/work/ibm">IBM · CAS</a>
          <a href="/work/ventures">Ventures</a>
        </div>
      </span>
      <a href="#pubs">PUBLICATIONS</a>
      <a href="#contact">CONTACT</a>
      <a href="/resume.pdf" class="res">RESUME ↓</a>
    </span>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background: var(--scrim);
    border-bottom: 1px solid var(--line);
  }

  .wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    /* Enlarge tap target without changing visual size */
    padding: 15px 0;
    margin: -15px 0;
  }

  .logo {
    display: block;
    width: 34px;
    height: 34px;
    overflow: visible;
  }

  .logo .ext {
    fill: none;
    stroke: var(--red);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .logo .front {
    fill: none;
    stroke: var(--ww);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .nlinks {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nlinks > a {
    color: var(--t3);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.12em;
    margin-left: 22px;
    transition: color 0.15s;
    /* Enlarge tap target to ≥44px without changing visual size */
    padding-top: 17px;
    padding-bottom: 17px;
    margin-top: -17px;
    margin-bottom: -17px;
  }

  .nlinks > a:hover {
    color: var(--ww);
    text-decoration: none;
  }

  .nlinks > a.res {
    color: var(--red);
  }

  .nlinks > a.res:hover {
    color: var(--ww);
  }

  /* Work dropdown */
  .dropdown {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin-left: 22px;
  }

  .trigger {
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--t3);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: color 0.15s;
    /* match nav-link tap target */
    padding: 17px 0;
    margin: -17px 0;
  }

  .trigger:hover,
  .dropdown:focus-within .trigger,
  .dropdown.open .trigger {
    color: var(--ww);
  }

  .caret {
    font-size: 8px;
    transition: transform 0.2s ease;
  }

  .dropdown.open .caret,
  .dropdown:focus-within .caret {
    transform: rotate(180deg);
  }

  .menu {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 8px;
    min-width: 150px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    z-index: 60;
  }

  .dropdown.open > .menu,
  .dropdown:focus-within > .menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (hover: hover) {
    .dropdown:hover > .menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown:hover .caret {
      transform: rotate(180deg);
    }
  }

  .menu a {
    color: var(--t3);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 9px 12px;
    border-radius: 5px;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
    /* reset the tap-target padding inherited from .nlinks > a */
    margin: 0;
  }

  .menu a:hover,
  .menu a:focus-visible {
    color: var(--ww);
    background: var(--line-faint);
  }

  @media (max-width: 520px) {
    .wrap {
      padding: 0 20px;
    }

    .dropdown {
      margin-left: 14px;
    }

    .nlinks > a {
      margin-left: 14px;
      font-size: 9px;
      letter-spacing: 0.08em;
      /* Keep enlarged tap target on mobile */
      padding-top: 17px;
      padding-bottom: 17px;
      margin-top: -17px;
      margin-bottom: -17px;
    }

    /* Hide PUBLICATIONS on very small screens */
    .nlinks > a:nth-child(2) {
      display: none;
    }
  }
</style>

<script>
  const dd = document.querySelector('.dropdown')
  if (dd) {
    const trigger = dd.querySelector('.trigger')
    trigger?.addEventListener('click', () => {
      const open = dd.classList.toggle('open')
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false')
    })
    document.addEventListener('click', (e) => {
      if (!dd.contains(e.target as Node)) {
        dd.classList.remove('open')
        trigger?.setAttribute('aria-expanded', 'false')
      }
    })
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dd.classList.contains('open')) {
        dd.classList.remove('open')
        trigger?.setAttribute('aria-expanded', 'false')
        ;(trigger as HTMLElement)?.focus()
      }
    })
  }
</script>
