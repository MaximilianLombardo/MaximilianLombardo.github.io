---
// Nav.astro — sticky translucent top bar
---

<nav>
  <div class="wrap">
    <a href="/" class="brand" aria-label="Maximilian Lombardo — home">
      <svg class="logo" viewBox="0 0 32 32" aria-hidden="true">
        <line class="s w" x1="5" y1="24" x2="5" y2="9" />
        <line class="s r" x1="5" y1="9" x2="14" y2="18" />
        <line class="s w" x1="14" y1="18" x2="23" y2="9" />
        <line class="s r" x1="23" y1="9" x2="23" y2="24" />
        <line class="s w" x1="23" y1="24" x2="30" y2="24" />
      </svg>
    </a>
    <span class="nlinks">
      <a href="#work">WORK</a>
      <a href="#pubs">PUBLICATIONS</a>
      <a href="#contact">CONTACT</a>
      <a href="/resume.pdf" class="res">RESUME ↓</a>
    </span>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background: var(--scrim);
    border-bottom: 1px solid var(--line);
  }

  .wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    /* Enlarge tap target without changing visual size */
    padding: 15px 0;
    margin: -15px 0;
  }

  .logo {
    display: block;
    width: 28px;
    height: 28px;
    overflow: visible;
  }

  .logo .s {
    fill: none;
    stroke-width: 3.8;
    stroke-linecap: round;
  }

  .logo .w {
    stroke: var(--ww);
  }

  .logo .r {
    stroke: var(--red);
  }

  .nlinks {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nlinks a {
    color: var(--t3);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.12em;
    margin-left: 22px;
    transition: color 0.15s;
    /* Enlarge tap target to ≥44px without changing visual size */
    padding-top: 17px;
    padding-bottom: 17px;
    margin-top: -17px;
    margin-bottom: -17px;
  }

  .nlinks a:hover {
    color: var(--ww);
    text-decoration: none;
  }

  .nlinks a.res {
    color: var(--red);
  }

  .nlinks a.res:hover {
    color: var(--ww);
  }

  @media (max-width: 520px) {
    .wrap {
      padding: 0 20px;
    }

    .nlinks a {
      margin-left: 14px;
      font-size: 9px;
      letter-spacing: 0.08em;
      /* Keep enlarged tap target on mobile */
      padding-top: 17px;
      padding-bottom: 17px;
      margin-top: -17px;
      margin-bottom: -17px;
    }

    /* Hide PUBLICATIONS on very small screens */
    .nlinks a:nth-child(2) {
      display: none;
    }
  }
</style>
