---
// Nav.astro: sticky translucent top bar
---

<nav>
  <div class="wrap">
    <a href="/" class="brand" aria-label="Maximilian Lombardo, home">
      <svg class="logo" viewBox="0 0 32 32" aria-hidden="true">
        <!-- red isometric extrusion (behind) -->
        <polyline class="ext" points="8,22.5 8,9.5 15,16.5 22,9.5 22,22.5" />
        <line class="ext" x1="7" y1="23" x2="8" y2="22.5" />
        <line class="ext" x1="7" y1="10" x2="8" y2="9.5" />
        <line class="ext" x1="14" y1="17" x2="15" y2="16.5" />
        <line class="ext" x1="21" y1="10" x2="22" y2="9.5" />
        <line class="ext" x1="21" y1="23" x2="22" y2="22.5" />
        <!-- white front M -->
        <polyline class="front" points="7,23 7,10 14,17 21,10 21,23" />
      </svg>
    </a>
    <span class="nlinks">
      <span class="dropdown">
        <button type="button" class="trigger" aria-haspopup="true" aria-expanded="false">
          WORK <span class="caret" aria-hidden="true">▾</span>
        </button>
        <div class="menu">
          <a href="/work/biohub">Biohub</a>
          <a href="/work/kallyope">Kallyope</a>
          <a href="/work/ibm">IBM · CAS</a>
          <a href="/work/ventures">Ventures</a>
        </div>
      </span>
      <a href="#pubs">PUBLICATIONS</a>
      <a href="#contact">CONTACT</a>
      <a href="/resume.pdf" class="res">RESUME ↓</a>
    </span>

    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobile-menu">
    <span class="mm-label">Work</span>
    <a class="sub" href="/work/biohub">Biohub</a>
    <a class="sub" href="/work/kallyope">Kallyope</a>
    <a class="sub" href="/work/ibm">IBM · CAS</a>
    <a class="sub" href="/work/ventures">Ventures</a>
    <span class="mm-div"></span>
    <a href="#pubs">Publications &amp; Workshops</a>
    <a href="#contact">Contact</a>
    <a class="mm-res" href="/resume.pdf">Resume ↓</a>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    background: var(--scrim);
    border-bottom: 1px solid var(--line);
  }

  .wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    /* Enlarge tap target without changing visual size */
    padding: 15px 0;
    margin: -15px 0;
  }

  .logo {
    display: block;
    width: 34px;
    height: 34px;
    overflow: visible;
  }

  .logo .ext {
    fill: none;
    stroke: var(--red);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .logo .front {
    fill: none;
    stroke: var(--ww);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .nlinks {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .nlinks > a {
    color: var(--t3);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.12em;
    margin-left: 22px;
    transition: color 0.15s;
    /* Enlarge tap target to ≥44px without changing visual size */
    padding-top: 17px;
    padding-bottom: 17px;
    margin-top: -17px;
    margin-bottom: -17px;
  }

  .nlinks > a:hover {
    color: var(--ww);
    text-decoration: none;
  }

  .nlinks > a.res {
    color: var(--red);
  }

  .nlinks > a.res:hover {
    color: var(--ww);
  }

  /* Work dropdown */
  .dropdown {
    position: relative;
    display: inline-flex;
    align-items: center;
    margin-left: 22px;
  }

  .trigger {
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--t3);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    display: inline-flex;
    align-items: center;
    gap: 5px;
    transition: color 0.15s;
    /* match nav-link tap target */
    padding: 17px 0;
    margin: -17px 0;
  }

  .trigger:hover,
  .dropdown:focus-within .trigger,
  .dropdown.open .trigger {
    color: var(--ww);
  }

  .caret {
    font-size: 8px;
    transition: transform 0.2s ease;
  }

  .dropdown.open .caret,
  .dropdown:focus-within .caret {
    transform: rotate(180deg);
  }

  .menu {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 8px;
    min-width: 150px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s;
    z-index: 60;
  }

  .dropdown.open > .menu,
  .dropdown:focus-within > .menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (hover: hover) {
    .dropdown:hover > .menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .dropdown:hover .caret {
      transform: rotate(180deg);
    }
  }

  .menu a {
    color: var(--t3);
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.06em;
    padding: 9px 12px;
    border-radius: 5px;
    white-space: nowrap;
    transition: color 0.15s, background 0.15s;
    /* reset the tap-target padding inherited from .nlinks > a */
    margin: 0;
  }

  .menu a:hover,
  .menu a:focus-visible {
    color: var(--ww);
    background: var(--line-faint);
  }

  /* Hamburger + mobile menu (hidden on desktop) */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    margin-right: -8px;
    padding: 0;
    background: none;
    border: 0;
    cursor: pointer;
  }

  .bar {
    display: block;
    width: 21px;
    height: 2px;
    margin: 0 auto;
    background: var(--ww);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 600px) {
    .wrap {
      padding: 0 20px;
    }

    /* Swap the inline links for a hamburger menu */
    .nlinks {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }

    .mobile-menu {
      display: flex;
      flex-direction: column;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--line);
      padding: 8px 20px 20px;
      opacity: 0;
      visibility: hidden;
      transform: translateY(-10px);
      transition: opacity 0.18s ease, transform 0.18s ease, visibility 0.18s;
    }

    nav.nav-open .mobile-menu {
      opacity: 1;
      visibility: visible;
      transform: translateY(0);
    }

    .mm-label {
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--t3);
      padding: 10px 0 6px;
    }

    .mm-div {
      height: 1px;
      background: var(--line);
      margin: 8px 0;
    }

    .mobile-menu a {
      color: var(--t2);
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 13px;
      letter-spacing: 0.04em;
      padding: 13px 2px;
      border-bottom: 1px solid var(--line-faint);
      transition: color 0.15s;
    }

    .mobile-menu a:hover,
    .mobile-menu a:active {
      color: var(--ww);
    }

    .mobile-menu a.sub {
      padding-left: 16px;
      font-size: 12px;
      color: var(--t3);
    }

    .mobile-menu a.sub:hover {
      color: var(--ww);
    }

    .mobile-menu a.mm-res {
      color: var(--red);
      border-bottom: 0;
    }

    /* hamburger morphs into an X when open */
    nav.nav-open .bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    nav.nav-open .bar:nth-child(2) {
      opacity: 0;
    }

    nav.nav-open .bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>

<script>
  const nav = document.querySelector('nav')
  const dd = document.querySelector('.dropdown')
  const toggle = document.querySelector('.menu-toggle')

  // Desktop: Work dropdown
  if (dd) {
    const trigger = dd.querySelector('.trigger')
    trigger?.addEventListener('click', () => {
      const open = dd.classList.toggle('open')
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false')
    })
    document.addEventListener('click', (e) => {
      if (!dd.contains(e.target as Node)) {
        dd.classList.remove('open')
        trigger?.setAttribute('aria-expanded', 'false')
      }
    })
  }

  // Mobile: hamburger menu
  if (nav && toggle) {
    const closeMenu = () => {
      nav.classList.remove('nav-open')
      toggle.setAttribute('aria-expanded', 'false')
    }
    toggle.addEventListener('click', () => {
      const open = nav.classList.toggle('nav-open')
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false')
    })
    // Close after choosing a destination
    nav.querySelectorAll('.mobile-menu a').forEach((a) =>
      a.addEventListener('click', closeMenu)
    )
    // Close when tapping outside the nav
    document.addEventListener('click', (e) => {
      if (nav.classList.contains('nav-open') && !nav.contains(e.target as Node)) {
        closeMenu()
      }
    })
  }

  // Escape closes either menu
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return
    dd?.classList.remove('open')
    dd?.querySelector('.trigger')?.setAttribute('aria-expanded', 'false')
    if (nav?.classList.contains('nav-open')) {
      nav.classList.remove('nav-open')
      toggle?.setAttribute('aria-expanded', 'false')
    }
  })
</script>
