---
---

<div class="band">
  <img
    class="tex"
    src="/posters/dither-band.webp"
    alt=""
    aria-hidden="true"
  />
  <div class="mask"></div>
  <div class="redpoint"></div>
  <a class="content" href="/lab" aria-label="Lab: generative art and interactive systems, coming soon">
    <span class="lab">CREATIVE TECHNOLOGY</span>
    <span class="headline">Generative art &amp; interactive systems <span class="arrow red">→</span></span>
    <span class="soon">COMING SOON</span>
  </a>
</div>

<style>
  .band {
    position: relative;
    height: 200px;
    overflow: hidden;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .tex {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
    filter: grayscale(1) brightness(0.85) contrast(1.15);
  }

  .mask {
    position: absolute;
    inset: 0;
    background: radial-gradient(120% 120% at 50% 50%, transparent, rgba(0, 0, 0, 0.75));
  }

  .redpoint {
    position: absolute;
    inset: 0;
    opacity: 0.35;
    mix-blend-mode: screen;
    background: radial-gradient(30% 60% at 62% 50%, rgba(255, 30, 45, 0.5), transparent 70%);
  }

  .content {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
  }

  .lab {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.22em;
    color: var(--t3);
  }

  .headline {
    font-weight: 300;
    font-size: 22px;
    color: var(--ww);
  }

  .red {
    color: var(--red);
  }

  .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .content:hover .headline {
    color: var(--ww);
  }

  .content:hover .arrow {
    transform: translateX(5px);
  }

  .soon {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--t3);
    border: 1px solid var(--line);
    border-radius: 9999px;
    padding: 4px 9px;
    margin-top: 4px;
    transition: color 0.15s, border-color 0.15s;
  }

  .content:hover .soon {
    color: var(--ww);
    border-color: var(--t3);
  }
</style>
