---
import Base from '../layouts/Base.astro'
import Footer from '../components/Footer.astro'
---

<Base
  title="Lab — Maximilian Lombardo"
  description="Generative art, shaders, and interactive systems — a gallery of experiments. Coming soon."
>
  <div class="wrap">
    <a href="/" class="back">← Back to home</a>

    <div class="texture" aria-hidden="true">
      <img src="/posters/dither-band.webp" alt="" />
    </div>

    <header class="page-header">
      <span class="label">Creative Technology</span>
      <h1>Lab</h1>
      <p class="tagline">Generative art, shaders &amp; interactive systems.</p>
      <span class="badge"><span class="dot"></span> Coming soon</span>
    </header>

    <div class="content">
      <p class="lead">
        A gallery of generative-art experiments — WebGL shaders, particle systems, and
        interactive pieces built with tools like Three.js and TouchDesigner. It's in the
        works; check back soon.
      </p>
      <p class="meta">
        In the meantime, the hero on the <a href="/">home page</a> is one of these
        experiments running live.
      </p>
    </div>
  </div>

  <Footer />
</Base>

<style>
  .wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 40px 80px;
  }

  .back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--t3);
    text-decoration: none;
    text-transform: uppercase;
    margin-bottom: 40px;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--ww);
  }

  .texture {
    height: 120px;
    border: 1px solid var(--line);
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 44px;
  }

  .texture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: grayscale(1) brightness(0.85) contrast(1.15);
  }

  .page-header {
    margin-bottom: 44px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--line);
  }

  .label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 200;
    letter-spacing: -0.02em;
    line-height: 1.02;
    color: var(--ww);
    margin-bottom: 14px;
  }

  .tagline {
    font-size: 17px;
    font-weight: 300;
    color: var(--t2);
    margin-bottom: 20px;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--t3);
    border: 1px solid var(--line);
    border-radius: 9999px;
    padding: 6px 12px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 9999px;
    background: var(--red);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot { animation: none; }
  }

  .content {
    max-width: 620px;
  }

  .lead {
    font-size: 16px;
    line-height: 1.7;
    color: var(--t2);
    margin-bottom: 20px;
  }

  .meta {
    font-size: 14px;
    line-height: 1.7;
    color: var(--t3);
  }

  a {
    color: var(--red);
    text-decoration: none;
  }

  .content a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .wrap {
      padding: 24px 20px 60px;
    }
  }
</style>
