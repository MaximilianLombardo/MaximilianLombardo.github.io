---
import Base from '../layouts/Base.astro'
import Nav from '../components/Nav.astro'
import Hero from '../components/Hero.astro'
import Section from '../components/Section.astro'
import Work from '../components/Work.astro'
import Publications from '../components/Publications.astro'
import DitherBand from '../components/DitherBand.astro'
import Contact from '../components/Contact.astro'
import Footer from '../components/Footer.astro'
---

<Base title="Maximilian Lombardo">
  <Nav />
  <Hero />

  <div class="wrap">
    <Section n="00" name="About">
      <h2>Productizing foundation models and AI tools for the people doing cell science.</h2>
      <p class="body">
        At <a class="link" href="https://www.czbiohub.org/">Biohub</a> I turn research models into products computational biologists actually use.
        I came to product from a computational-biology background, pairing technical depth with creative problem-solving.
      </p>
      <div class="tags">
        <span class="tag">Product · 0→1</span>
        <span class="tag">AI &amp; Foundation Models</span>
        <span class="tag">Single-cell / Genomics</span>
        <span class="tag">Python · PyTorch</span>
        <span class="tag">React</span>
        <span class="tag">Creative Tech</span>
      </div>
    </Section>

    <Section n="01" name="Work" id="work">
      <Work />
    </Section>

    <Section n="02" name="Publications" id="pubs">
      <Publications />
    </Section>
  </div>

  <DitherBand />

  <div class="wrap">
    <Section n="03" name="Contact" id="contact">
      <Contact />
    </Section>
  </div>

  <Footer />
</Base>

<style>
  .wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 40px;
  }

  h2 {
    color: var(--ww);
    font-weight: 300;
    font-size: clamp(24px, 3.5vw, 34px);
    letter-spacing: -0.015em;
    line-height: 1.12;
    max-width: 720px;
  }

  .body {
    font-size: 16px;
    line-height: 1.6;
    color: var(--t2);
    max-width: 600px;
    margin-top: 16px;
  }

  .link {
    color: var(--red);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--red) 35%, transparent);
  }

  .tags {
    margin-top: 22px;
  }

  .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0.06em;
    color: var(--t3);
    border: 1px solid var(--line);
    border-radius: 9999px;
    padding: 7px 12px;
    margin: 0 7px 8px 0;
    text-transform: uppercase;
  }
</style>
