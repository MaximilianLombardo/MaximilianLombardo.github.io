---
import Base from '../../layouts/Base.astro'
import Footer from '../../components/Footer.astro'
---

<Base
  title="IBM Center for Advanced Studies — Maximilian Lombardo"
  description="Full detail on Maximilian Lombardo's ML research internship at IBM Center for Advanced Studies: frameworks for multi-omics disease research."
>
  <div class="wrap">
    <a href="/" class="back">← Back to home</a>

    <header class="page-header">
      <span class="label">01 / WORK</span>
      <h1><a href="https://www.ibm.com/university/academic/home/">IBM Center for Advanced Studies</a></h1>
      <p class="tagline">ML Research Intern</p>
      <span class="badge">ML RESEARCH INTERN</span>
    </header>

    <div class="content">
      <p class="lead">
        Graduate ML research intern at the <a href="https://www.ibm.com/university/academic/home/">IBM Center for Advanced Studies</a>,
        developing frameworks for multi-omics disease research.
      </p>
    </div>
  </div>

  <Footer />
</Base>

<style>
  .wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 40px 40px 80px;
  }

  .back {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--t3);
    text-decoration: none;
    text-transform: uppercase;
    margin-bottom: 48px;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--ww);
    text-decoration: none;
  }

  .page-header {
    margin-bottom: 52px;
    padding-bottom: 40px;
    border-bottom: 1px solid var(--line);
  }

  .label {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--red);
    margin-bottom: 16px;
  }

  h1 {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 200;
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin-bottom: 12px;
  }

  h1 a {
    color: var(--ww);
    text-decoration: none;
  }

  h1 a:hover {
    text-decoration: none;
    color: var(--ww);
  }

  .tagline {
    font-size: 16px;
    color: var(--t2);
    margin-bottom: 16px;
  }

  .badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--t3);
    border: 1px solid var(--line);
    border-radius: 9999px;
    padding: 5px 10px;
    text-transform: uppercase;
  }

  .lead {
    font-size: 17px;
    line-height: 1.65;
    color: var(--t2);
    max-width: 680px;
    margin-bottom: 52px;
  }

  .content {
    max-width: 680px;
  }

  .section {
    margin-bottom: 44px;
    padding-bottom: 44px;
    border-bottom: 1px solid var(--line-faint);
  }

  .section:last-child {
    border-bottom: none;
  }

  h2 {
    font-size: 20px;
    font-weight: 300;
    letter-spacing: -0.01em;
    color: var(--ww);
    margin-bottom: 14px;
  }

  p {
    font-size: 15px;
    line-height: 1.7;
    color: var(--t2);
  }

  a {
    color: var(--red);
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  @media (max-width: 600px) {
    .wrap {
      padding: 24px 20px 60px;
    }
  }
</style>
